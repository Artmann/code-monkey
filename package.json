{
  "name": "@artmann/codemonkey",
  "productName": "code-monkey",
  "version": "0.1.3",
  "description": "A local-first desktop workbench for coding agents. Each task runs in its own isolated git worktree with a streaming agent view.",
  "main": "dist/main/main.js",
  "bin": {
    "codemonkey": "bin/codemonkey.js"
  },
  "files": [
    "bin",
    "dist",
    "scripts/postinstall.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm typecheck && pnpm lint && pnpm test:run && pnpm make",
    "build:npm": "node scripts/build-npm.mjs",
    "db:generate": "drizzle-kit generate",
    "lint": "eslint --ext .ts,.tsx src",
    "make": "electron-forge make",
    "package": "electron-forge package",
    "postinstall": "node scripts/postinstall.mjs",
    "prepack": "pnpm build:npm",
    "release": "pnpm build && electron-forge publish",
    "start": "electron-forge start",
    "task:inspect": "node scripts/task-inspect.mjs",
    "test:run": "vitest run",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "electron",
    "coding-agent",
    "agents",
    "codex",
    "openai",
    "task-management",
    "developer-tools",
    "worktree",
    "ai",
    "desktop"
  ],
  "author": {
    "name": "Christoffer Artmann",
    "email": "artgaard@gmail.com"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "better-sqlite3",
      "esbuild",
      "electron-winstaller"
    ]
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.7.0",
    "drizzle-kit": "^0.31.10",
    "electron": "41.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.6.3",
    "vite": "^5.4.21",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron/rebuild": "^3.7.0",
    "@emotion/is-prop-valid": "^1.4.0",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.7.6",
    "@openai/codex-sdk": "^0.121.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.99.0",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.2",
    "electron": "41.2.1",
    "electron-squirrel-startup": "^1.0.1",
    "framer-motion": "^12.38.0",
    "hono": "^4.12.14",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hotkeys-hook": "^5.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tiny-invariant": "^1.3.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
